#include <SPI.h>
#include <TFT_eSPI.h>
#include <XPT2046_Touchscreen.h>
#include <Preferences.h>

#define TOUCH_CS_PIN 21
XPT2046_Touchscreen touch(TOUCH_CS_PIN);
TFT_eSPI tft = TFT_eSPI();
Preferences prefs;

int p_rawX[5], p_rawY[5];
int puntoActual = 0;
bool calibracionTerminada = false;
bool guardadoRealizado = false;

// Coordenadas de dibujo de los puntos (Pixeles)
int puntosX[] = {30, 450, 30, 450, 240};
int puntosY[] = {30, 30, 290, 290, 160};
const char* nombres[] = {"1. Sup Izq", "2. Sup Der", "3. Inf Izq", "4. Inf Der", "5. Centro"};

void dibujarCruz(int x, int y, uint16_t color) {
  tft.drawLine(x - 15, y, x + 15, y, color);
  tft.drawLine(x, y - 15, x, y + 15, color);
  tft.drawCircle(x, y, 10, color);
}

void setup() {
  Serial.begin(115200);
  tft.init();
  tft.setRotation(1);
  tft.fillScreen(TFT_BLACK);
  
  touch.begin();
  touch.setRotation(1);

  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.drawCentreString("CALIBRACION PASO A PASO", 240, 100, 2);
  tft.drawCentreString("Sigue el orden de los circulos", 240, 130, 2);
  
  // Dibujar el primer punto
  dibujarCruz(puntosX[0], puntosY[0], TFT_RED);
  tft.drawCentreString(nombres[0], 240, 200, 2);
}

void loop() {
  if (touch.touched()) {
    TS_Point p = touch.getPoint();

    // FASE 1: Recogida de puntos
    if (puntoActual < 5) {
      p_rawX[puntoActual] = p.x;
      p_rawY[puntoActual] = p.y;
      
      tft.fillScreen(TFT_BLACK);
      puntoActual++;
      
      if (puntoActual < 5) {
        dibujarCruz(puntosX[puntoActual], puntosY[puntoActual], TFT_RED);
        tft.drawCentreString(nombres[puntoActual], 240, 200, 2);
      } else {
        // FASE 2: Mostrar botón de guardado
        tft.fillScreen(TFT_BLACK);
        tft.fillRect(90, 110, 300, 100, TFT_BLUE);
        tft.drawRect(90, 110, 300, 100, TFT_WHITE);
        tft.setTextColor(TFT_WHITE);
        tft.drawCentreString("CALIBRACION LISTA", 240, 135, 2);
        tft.drawCentreString("PULSA AQUI PARA GUARDAR", 240, 165, 2);
        calibracionTerminada = true;
      }
      delay(500);
    } 
    // FASE 3: Detección de pulsación en el botón
    else if (calibracionTerminada && !guardadoRealizado) {
      // Mapeo temporal para detectar el botón (usando valores estándar)
      int tx = map(p.x, p_rawX[0], p_rawX[1], 30, 450);
      int ty = map(p.y, p_rawY[0], p_rawY[2], 30, 290);

      if (tx > 90 && tx < 390 && ty > 110 && ty < 210) {
        guardarDatos();
      }
    }
  }
}

void guardarDatos() {
  // Cálculo de promedios para mayor precisión
  int xMin = (p_rawX[0] + p_rawX[2]) / 2;
  int xMax = (p_rawX[1] + p_rawX[3]) / 2;
  int yMin = (p_rawY[0] + p_rawY[1]) / 2;
  int yMax = (p_rawY[2] + p_rawY[3]) / 2;

  prefs.begin("calib", false);
  prefs.putInt("xMin", xMin);
  prefs.putInt("xMax", xMax);
  prefs.putInt("yMin", yMin);
  prefs.putInt("yMax", yMax);
  prefs.end();

  guardadoRealizado = true;
  tft.fillScreen(TFT_GREEN);
  tft.setTextColor(TFT_BLACK);
  tft.drawCentreString("GUARDADO CORRECTO", 240, 150, 4);

  Serial.println("\n--- COPIA ESTA LINEA EN TU CODIGO ---");
  Serial.printf("int x = map(p.x, %d, %d, 0, 480);\n", xMin, xMax);
  Serial.printf("int y = map(p.y, %d, %d, 0, 320);\n", yMin, yMax);
  Serial.println("-------------------------------------\n");
}
